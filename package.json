{
  "name": "portafolio",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:prod": "ng build --base-href /portfolio/",
    "watch": "ng build --watch --configuration development",
    "test": "vitest run",
    "test:watch": "vitest",
    "serve:ssr:portafolio": "node dist/portafolio/server/server.mjs"
  },
  "private": true,
  "dependencies": {
